{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  "files.associations": {
    "*.db": "sqlite"
  },
  "explorer.fileNesting.enabled": false,
  "sqlite.showDatabaseFiles": true
}